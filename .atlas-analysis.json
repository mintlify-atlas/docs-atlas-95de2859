  "keyFeatures": [
    "Type-safe effect system for managing side effects and async operations",
    "Comprehensive error handling with Cause data type",
    "Lightweight fiber-based concurrency model",
    "Powerful Schema library for validation and transformation",
    "Dependency injection with Context and Layer",
    "Resource-safe management with automatic cleanup",
    "Composable scheduling for retry and repeat logic",
    "Stream processing for async, event-driven data",
    "Platform abstractions for Node.js, Bun, and browsers",
    "Built-in testing utilities and property-based testing",
    "CLI framework for building command-line applications",
    "HTTP API framework with automatic documentation",
    "SQL database utilities with type-safe queries",
    "OpenTelemetry integration for observability",
    "Distributed computing with cluster and RPC support"
  ],
